# ─── Database — Supabase PostgreSQL ──────────────────────────────────────────
# Get both values from: Supabase Dashboard → Project Settings → Database → Connection string
#
# 1. Transaction Mode pooler (port 6543) — used by Prisma at runtime.
#    Append ?pgbouncer=true&connection_limit=1 to avoid prepared-statement conflicts.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# 2. Direct connection (port 5432) — used by `prisma migrate` only.
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
#
# ─── Supabase Project Keys ────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# anon / public key — safe to expose in browser
SUPABASE_ANON_KEY="eyJ..."
# service_role key — NEVER expose publicly. Used by the NestJS API only.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
PORT=3000
DASHBOARD_ORIGIN=http://localhost:5173

# Data residency / sharding (Sovereign Data Act — Lagos vs Accra)
SHARD_REGION=LAGOS

# Optional dedicated secret for stateless biometric validation hashes (defaults to BSSS_MASTER_SECRET)
# EXECUTION_PROOF_SECRET=

BVN_PEPPER=change-me-in-production
BSSS_MASTER_SECRET=change-me-32-characters-minimum!!
BSSS_CRYPTO_SALT=change-me-32-byte-salt-prefer!!

# Stub NIBSS (default when NIBSS_BASE_URL unset): optional overrides match|nomatch|error
# STUB_NIBSS_FP=match
# STUB_NIBSS_FACE=nomatch
# STUB_NIBSS_MOBILE=match

# Live NIBSS (swap stubs when ready)
# NIBSS_BASE_URL=https://sandbox.nibss.example
# NIBSS_API_KEY=
# NIBSS_TIMEOUT_MS=2500

# Sentinel AND-gate threshold (minor units) when SENTINEL_BASE_URL unavailable
SENTINEL_AND_GATE_THRESHOLD_MINOR=10000000
DEFAULT_CURRENCY=NGN
# SENTINEL_BASE_URL=https://sentinel.example
# Full URL overrides path join for POS stealth + GPS (3 failed unlocks)
# SENTINEL_STEALTH_URL=https://sentinel.example/v1/pos/stealth-capture
# SENTINEL_STEALTH_PATH=/v1/pos/stealth-capture

# BVN consecutive-failure rate limiter (VerificationService → SentinelService)
# Alert fires when BVN_FAILURE_THRESHOLD consecutive failures occur within BVN_FAILURE_WINDOW_MIN minutes
BVN_FAILURE_THRESHOLD=5
BVN_FAILURE_WINDOW_MIN=60

# POS Terminal Control: inactivity HARD_LOCK (minutes) while UNLOCKED
TERMINAL_INACTIVITY_MINUTES=20

# Execution suite: require biometricValidationHash on transfer/withdraw/bills (set false only for dev)
EXECUTION_REQUIRE_HASH_ONLY=true
# TTL for minted validation hash (seconds)
EXECUTION_HASH_TTL_SEC=90

# Passive liveness: set true only in dev/tests
LIVENESS_BYPASS=true

# LLIW — Liquidity-Linked Incentive & Withdrawal Gate
# Direct Core Banking (CBS) API — stub (console.warn) when unset
# CBS_BASE_URL=https://cbs.partnerbank.example
# F-Man Operations Account reference at the partner bank (source of daily agent incentives)
FMAN_OPS_ACCOUNT_REF=FMAN-OPS-DEFAULT

# BEPWG — Biometric Exchequer & Proximity Withdrawal Gate
# AES-256-GCM key for offline POS proximity cache (must be exactly 32 chars in production)
OFFLINE_CACHE_SECRET=offline-cache-secret-32-chars!!
# HMAC secret for offline cache token signature validation
OFFLINE_CACHE_HMAC_SECRET=offline-hmac-secret-change-in-prod

# LBAS — Liveness, External Biometric & Networkless Authentication Suite
# AES-256-GCM key for encrypting TOTP seeds (must be 32 chars in production)
LBAS_TOTP_KEY=lbas-totp-key-32-chars-minimum!
# Push notification gateway (FCM/APNS) — stub (console.warn) when unset
# PUSH_BASE_URL=https://push.fman.example

# UNWP — Universal Networkless Withdrawal Protocol
# AES-256-GCM key burned into POS terminal during binding (must be 32 chars in production)
POS_LEDGER_KEY=pos-ledger-key-32-chars-minimum!

# ZFOE — Zero-Friction Instant Onboarding Engine
# AES-256-GCM key for encrypting Shadow Profile blobs at rest (must be 32 chars in production)
ZFOE_SHADOW_KEY=zfoe-shadow-key-32-chars-minimum!

# BIH — Biometric Identity Harvest & Instant Account Mint
# AES-256-GCM key for encrypting minutiae before NIBSS transit (must be 32 chars in production)
BIH_TEMPLATE_KEY=bih-template-key-32-chars-minimum
# AES-256-GCM key for encrypting NIBSS identity package at rest (must be 32 chars in production)
BIH_SHADOW_KEY=bih-shadow-key-32-chars-minimum!!

# BLS-TSA — Biometric Liquidity Sweep & Two-Step Authorization
# AES-256-GCM key for encrypting the discovered account map at rest (must be 32 chars in production)
BLS_ACCOUNT_KEY=bls-account-key-32-chars-padded!!
# AES-256-GCM key for minting + validating the opaque session token
BLS_SESSION_KEY=bls-session-key-32-chars-padded!!

# BLIDE — Biometric Liveness & Identity Discovery Engine
# AES-256-GCM key for encrypting face templates before NIBSS transit (must be 32 chars in production)
BLIDE_FACE_KEY=blide-face-key-32-chars-padded!!!
# AES-256-GCM key for encrypting identity/account blobs at rest (must be 32 chars in production)
BLIDE_SHADOW_KEY=blide-shadow-key-32-chars-padded!

# ─── ZFPS — Zero-Friction Provisioning Stack ────────────────────────────────
# Redis — 60-second NDPR identity vault + session state cache
# In-memory fallback activates automatically when REDIS_URL is unset (dev only)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@prod-redis.example.com:6379

# Termii SMS — instant account number delivery after CBS account creation
# Stub mode (console.log) activates when TERMII_API_KEY is unset
# TERMII_API_KEY=your-termii-api-key-here
# TERMII_SENDER_ID=F-ManNG

# Bank CBS latency alert threshold (milliseconds) — AdminRedFlag if moving avg exceeds this
# Default: 45000 (45 seconds per ZFPS spec)
ZFPS_LATENCY_ALERT_MS=45000

# gRPC internal service address (when @nestjs/microservices + @grpc/grpc-js are installed)
# ZFPS_GRPC_URL=localhost:50051
